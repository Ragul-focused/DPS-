<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Daily Log Sheet</title>
    <style>
        *,
        *::before,
        *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background: #b0b5bb;
            font-family: Arial, sans-serif;
            padding: 16px;
        }

        /* ── TOOLBAR ── */
        .toolbar {
            background: #1c2640;
            color: #fff;
            padding: 7px 16px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-radius: 4px;
            margin-bottom: 14px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, .3);
        }

        .tb-title {
            font-weight: 900;
            font-size: .95rem;
            letter-spacing: .1em;
            text-transform: uppercase;
            color: #f5c842;
        }

        .tb-r {
            display: flex;
            gap: .6rem;
            align-items: center;
        }

        .tb-date-box {
            background: rgba(255, 255, 255, .1);
            border: 1px solid rgba(255, 255, 255, .22);
            border-radius: 3px;
            padding: 4px 9px;
            font-size: .72rem;
            color: #ddd;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .tb-date-box input[type=date] {
            background: transparent;
            border: none;
            color: #f5c842;
            font-size: .72rem;
            outline: none;
            cursor: pointer;
            width: 114px;
        }

        .tb-date-box input::-webkit-calendar-picker-indicator {
            filter: invert(1) sepia(1) saturate(3) hue-rotate(5deg);
            cursor: pointer;
        }

        .print-btn {
            background: #f5c842;
            color: #111;
            border: none;
            border-radius: 3px;
            padding: 5px 14px;
            font-weight: 800;
            font-size: .78rem;
            letter-spacing: .08em;
            text-transform: uppercase;
            cursor: pointer;
        }

        .print-btn:hover {
            background: #ffd060;
        }

        /* ── PAGE ── */
        .page {
            background: #fff;
            border: 1.5px solid #666;
            box-shadow: 0 2px 14px rgba(0, 0, 0, .22);
            max-width: 1260px;
            margin: 0 auto 20px;
        }

        .pg-label {
            font-size: .6rem;
            font-weight: 700;
            letter-spacing: .1em;
            text-transform: uppercase;
            color: #888;
            text-align: center;
            padding: 2px 0;
            background: #f0f2f5;
            border-bottom: 1px solid #ccc;
        }

        /* ── TWO-PANEL SPLIT ── */
        .panels {
            display: grid;
            grid-template-columns: 1fr 1fr;
        }

        .panel {
            border-right: 3px solid #000;
        }

        .panel:last-child {
            border-right: none;
        }

        /* ── TABLE BASE ── */
        table {
            width: 100%;
            border-collapse: collapse;
        }

        td {
            border: 1px solid #aaa;
            padding: 0;
            height: 21px;
            vertical-align: middle;
            font-size: .62rem;
        }

        input {
            display: block;
            width: 100%;
            height: 100%;
            min-height: 21px;
            border: none;
            outline: none;
            font-size: .62rem;
            padding: 0 3px;
            background: transparent;
            color: #111;
        }

        input:focus {
            background: #fffce0;
        }

        input[type=number] {
            text-align: center;
        }

        /* ── HEADER CELLS ── */
        .hc {
            font-weight: 800;
            font-size: .64rem;
            text-transform: uppercase;
            letter-spacing: .04em;
            text-align: center;
            border: 1.5px solid #000 !important;
            background: #fff;
            height: 22px !important;
        }

        .hc.L {
            text-align: left;
            padding-left: 5px;
        }

        /* date sub-row */
        .dc {
            font-weight: 700;
            font-size: .6rem;
            text-transform: uppercase;
            text-align: center;
            border: 1px solid #666 !important;
            background: #f8f8f8;
            height: 19px !important;
        }

        /* size header */
        .sc {
            font-weight: 900;
            font-size: .65rem;
            text-align: center;
            border: 1px solid #555 !important;
            background: #f3f3f3;
            height: 22px !important;
        }

        .sc.div {
            background: #fff;
            border-left: 2px solid #000 !important;
            border-right: none !important;
            width: 2px !important;
            padding: 0 !important;
        }

        /* size data */
        .sd {
            height: 21px;
        }

        .sd.div {
            background: #fff;
            border-left: 2px solid #000 !important;
            border-right: none !important;
            width: 2px !important;
            padding: 0 !important;
        }

        /* company header */
        .cch {
            font-weight: 900;
            font-size: .66rem;
            text-transform: uppercase;
            text-align: center;
            border: 1.5px solid #000 !important;
            background: #f8f8f8;
            height: 22px !important;
        }

        .cch.L {
            text-align: left;
            padding-left: 5px;
        }

        /* O/B C/B rows */
        .ob td,
        .cb td {
            border: 2px solid #000 !important;
            font-weight: 900;
            font-size: .68rem;
            text-transform: uppercase;
            height: 26px !important;
        }

        .ob td.lbl,
        .cb td.lbl {
            text-align: right;
            padding-right: 6px;
            background: #f5f5f5;
        }

        .ob td.val,
        .cb td.val {
            border-left: 2.5px solid #000 !important;
        }

        .ob input,
        .cb input {
            font-weight: 700;
            font-size: .68rem;
        }

        /* section borders */
        .sec-top {
            border-top: 2.5px solid #000 !important;
        }

        .sec-top td {
            border-top: 2.5px solid #000 !important;
        }



        /* ── PRINT ── */
        @media print {
            body {
                background: #fff;
                padding: 0;
            }

            .toolbar,
            .pg-label {
                display: none !important;
            }

            .page {
                box-shadow: none;
                border: none;
                margin: 0;
                max-width: 100%;
                page-break-after: always;
            }

            .page:last-child {
                page-break-after: auto;
            }

            @page {
                size: A4 landscape;
                margin: 5mm;
            }
        }
    </style>
</head>

<body>

    <!-- TOOLBAR -->
    <div class="toolbar">
        <div class="tb-title">📒 Daily Log Sheet — Elite Preforms</div>
        <div class="tb-r">
            <div class="tb-date-box">DATE: <input type="date" id="tbDate" /></div>
            <button class="print-btn" onclick="window.print()">🖨 Print</button>
        </div>
    </div>

    <!-- PAGE 1: FRONT -->
    <div class="page" id="pg1">
        <div class="pg-label">Page 1 — Front Side</div>
        <div class="panels">
            <div class="panel" id="f1"></div>
            <div class="panel" id="f2"></div>
        </div>
    </div>

    <!-- PAGE 2: BACK -->
    <div class="page" id="pg2">
        <div class="pg-label">Page 2 — Back Side</div>
        <div class="panels">
            <div class="panel" id="b1"></div>
            <div class="panel" id="b2"></div>
        </div>
    </div>

    <script>
        /* ═══════════════════════════════════
           SIZES definition
           blank = visual divider column
        ═══════════════════════════════════ */
        /* Column widths — must match between size grid and company section
           ['',  'P',  'L',  '|',  'P',  'L',  '9.4','12.6','N',  'G',  '19.5','2L', '9.2']
           blank narrow, then equal cols for everything else */
        const COL_WIDTHS = ['4%', '7%', '7%', '7%', '7%', '7%', '7%', '9%', '7%', '7%', '9%', '7%', '7%'];
        // Total = 4+7*9+9*2 = 4+63+18 = 85... adjust to 100%
        // Recalc: 4 + 7+7+7 + 7+7+7+9+7+7+9+7+7 = 4+21+76 = hmm, let's just use flex %

        const SIZES = ['', 'P', 'L', '|', 'P', 'L', '9.4', '12.6', 'N', 'G', '19.5', '2L', '9.2'];
        // Give blank col narrow, | same as MODE col, rest equal
        const TOTAL = SIZES.length; // 13
        const BLANK_W = 5;   // leading blank col %
        const DIV_W = 7;   // | divider = same as MODE col
        const REST_W = ((100 - BLANK_W - DIV_W) / (TOTAL - 2)).toFixed(3); // remaining 11 cols equally

        function colW(i) {
            if (i === 0) return BLANK_W + '%';   // leading blank
            if (i === 3) return DIV_W + '%';     // | divider
            return REST_W + '%';
        }
        const SCOL = REST_W + '%'; // fallback

        const MAIN_ROWS = 14;
        const CO_ROWS = 8;

        /* ─────────────────────────────────────
           BUILD FRONT PANEL (top→bottom order)
        ───────────────────────────────────── */
        function frontPanel(id) {
            let h = '';

            /* == TRANSACTION TABLE == */
            h += `<table>
    <colgroup>
      <col style="width:38%"/>
      <col style="width:13%"/>
      <col style="width:9%"/>
      <col style="width:20%"/>
      <col style="width:20%"/>
    </colgroup>`;

            /* Row 1: top spacer / date area */
            h += `<tr>
    <td colspan="3" class="hc L" style="border-bottom:1px solid #aaa !important;"></td>
    <td class="hc" style="font-size:.6rem; letter-spacing:.03em; text-align:right; padding-right:4px;">DATE</td>
    <td class="hc" style="padding:0;">
      <input type="date" id="${id}_date" style="
        width:100%; height:100%; min-height:22px; border:none; outline:none;
        font-size:.62rem; font-family:Arial,sans-serif; font-weight:700;
        background:transparent; color:#1a3a6b; cursor:pointer; padding:0 3px;
        text-align:center;
      "/>
    </td>
  </tr>`;

            /* Row 2: column headers */
            h += `<tr>
    <td colspan="2" class="hc L">PARTICULAR</td>
    <td class="hc">MODE</td>
    <td class="hc">IN AMT.</td>
    <td class="hc">OUT AMT.</td>
  </tr>`;

            /* Data rows */
            for (let i = 0; i < MAIN_ROWS; i++) {
                h += `<tr>
      <td colspan="2" style="border-top:${i === 0 ? '2px solid #000' : '1px solid #aaa'}">
        <input type="text" id="${id}_p${i}"/>
      </td>
      <td style="border-top:${i === 0 ? '2px solid #000' : '1px solid #aaa'}">
        <input type="text" id="${id}_mo${i}"/>
      </td>
      <td style="border-top:${i === 0 ? '2px solid #000' : '1px solid #aaa'}">
        <input type="number" step="any" id="${id}_in${i}"/>
      </td>
      <td style="border-top:${i === 0 ? '2px solid #000' : '1px solid #aaa'}">
        <input type="number" step="any" id="${id}_ot${i}"/>
      </td>
    </tr>`;
            }
            h += `</table>`;

            /* == SIZE GRID + COMPANY SECTION — single unified table for perfect alignment ==
               13 columns matching SIZES: ['','P','L','|','P','L','9.4','12.6','N','G','19.5','2L','9.2']
               COMPANY NAME spans cols 0-2 (blank+P+L)
               MODE          = col 3  (the | divider column)
               boxes         = cols 4-12 (P L 9.4 12.6 N G 19.5 2L 9.2) = 9 boxes
            */
            const CO_BOXES = 9; // cols after MODE (cols 4-12)
            const totalCols = SIZES.length; // 13

            h += `<table style="border-top:2.5px solid #000"><colgroup>`;
            SIZES.forEach((s, i) => h += `<col style="width:${colW(i)}"/>`);
            h += `</colgroup>`;

            /* ── SIZE HEADER ROW ── */
            h += `<tr>`;
            SIZES.forEach(s => {
                if (s === '|') h += `<td class="sc div"></td>`;
                else h += `<td class="sc">${s}</td>`;
            });
            h += `</tr>`;

            /* ── SIZE DATA ROWS ── */
            for (let r = 0; r < 4; r++) {
                h += `<tr>`;
                SIZES.forEach((s, ci) => {
                    if (s === '|') h += `<td class="sd div"></td>`;
                    else if (s === '') h += `<td class="sd"></td>`;
                    else h += `<td class="sd"><input type="number" step="any" id="${id}_sz${r}_${ci}"/></td>`;
                });
                h += `</tr>`;
            }
            /* one blank extra row */
            h += `<tr>`;
            SIZES.forEach(s => h += `<td class="sd${s === '|' ? ' div' : ''}"></td>`);
            h += `</tr>`;

            /* ── COMPANY HEADER ROW ── */
            // COMPANY NAME = cols 0-2 (blank+P+L), MODE = col 3 (|), boxes = cols 4-12
            h += `<tr style="border-top:2.5px solid #000">
    <td colspan="3" class="cch L" style="border-top:2.5px solid #000 !important">COMPANY NAME</td>
    <td class="cch" style="border-top:2.5px solid #000 !important; border-left:2px solid #000 !important; border-right:2px solid #000 !important">MODE</td>`;
            for (let i = 0; i < CO_BOXES; i++) h += `<td class="cch" style="border-top:2.5px solid #000 !important"></td>`;
            h += `</tr>`;

            /* ── COMPANY DATA ROWS ── */
            for (let i = 0; i < CO_ROWS; i++) {
                h += `<tr>
      <td colspan="3"><input type="text" id="${id}_cn${i}"/></td>
      <td style="border-left:2px solid #000 !important; border-right:2px solid #000 !important">
        <input type="text" id="${id}_cm${i}"/>
      </td>`;
                for (let j = 0; j < CO_BOXES; j++) {
                    h += `<td><input type="number" step="any" id="${id}_cb${i}_${j}"/></td>`;
                }
                h += `</tr>`;
            }

            /* ── O/B ── */
            h += `<tr class="ob">
    <td class="lbl" colspan="${Math.floor(totalCols / 2)}">O/B-</td>
    <td class="val" colspan="${totalCols - Math.floor(totalCols / 2)}"><input type="number" step="any" id="${id}_ob"/></td>
  </tr>`;

            /* spacers */
            h += `<tr><td colspan="${totalCols}" style="height:22px;border:1px solid #aaa"></td></tr>`;
            h += `<tr><td colspan="${totalCols}" style="height:22px;border:1px solid #aaa"></td></tr>`;

            /* ── C/B ── */
            h += `<tr class="cb">
    <td class="lbl" colspan="${Math.floor(totalCols / 2)}">C/B-</td>
    <td class="val" colspan="${totalCols - Math.floor(totalCols / 2)}"><input type="number" step="any" id="${id}_cb"/></td>
  </tr>`;

            h += `</table>`;
            return h;
        }

        /* ─────────────────────────────────────
           BUILD BACK PANEL — same as front panel
           (page 2 of PDF is identical layout,
            just a second fresh page for more entries)
        ───────────────────────────────────── */
        function backPanel(id) {
            return frontPanel(id);
        }

        /* ── INJECT ── */
        document.getElementById('f1').innerHTML = frontPanel('f1');
        document.getElementById('f2').innerHTML = frontPanel('f2');
        document.getElementById('b1').innerHTML = backPanel('b1');
        document.getElementById('b2').innerHTML = backPanel('b2');

        /* ── AUTO DATE ── */
        const today = new Date();
        const yyyy = today.getFullYear();
        const mm = String(today.getMonth() + 1).padStart(2, '0');
        const dd = String(today.getDate()).padStart(2, '0');
        const dateVal = `${yyyy}-${mm}-${dd}`;

        document.getElementById('tbDate').value = dateVal;

        // Fill date input in all 4 panels
        ['f1', 'f2', 'b1', 'b2'].forEach(id => {
            const inp = document.getElementById(id + '_date');
            if (inp) inp.value = dateVal;
        });
    </script>
</body>

</html>
