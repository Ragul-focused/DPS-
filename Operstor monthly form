<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Monthly Time Sheet</title>
    <link href="https://fonts.googleapis.com/css2?family=Courier+Prime:wght@400;700&family=Bebas+Neue&display=swap"
        rel="stylesheet">
    <style>
        :root {
            --dark-blue: #0d1f4c;
            --yellow: #f5c518;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background: #e0e0e0;
            font-family: 'Courier Prime', monospace;
            color: #000;
            min-height: 100vh;
            padding: 30px 20px;
        }

        /* ── Title banner ── */
        .title-banner {
            background: var(--dark-blue);
            max-width: 1150px;
            margin: 0 auto 0;
            border-radius: 8px 8px 0 0;
            padding: 18px 28px 14px;
            text-align: center;
        }

        .page-title {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 3rem;
            letter-spacing: 0.18em;
            color: var(--yellow);
            text-transform: uppercase;
            line-height: 1;
            margin-bottom: 4px;
        }

        .page-subtitle {
            font-size: 0.85rem;
            letter-spacing: 0.3em;
            text-transform: uppercase;
            color: #a8bcd8;
        }

        /* ── Tabs ── */
        .tabs {
            display: flex;
            gap: 0;
            max-width: 1150px;
            margin: 0 auto;
        }

        .tab-btn {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 1.15rem;
            letter-spacing: 0.12em;
            padding: 10px 30px;
            cursor: pointer;
            border: 2px solid #000;
            border-bottom: none;
            background: #ccc;
            color: #555;
            transition: all 0.12s;
            position: relative;
            top: 2px;
        }

        .tab-btn:first-child {
            border-radius: 0;
        }

        .tab-btn:last-child {
            border-radius: 0;
        }

        .tab-btn.active {
            background: #fff;
            color: #000;
            font-weight: 700;
            z-index: 2;
        }

        .tab-btn:hover:not(.active) {
            background: #bbb;
            color: #000;
        }

        /* ── Sheet container ── */
        .sheet-container {
            background: #fff;
            border: 2px solid #000;
            border-radius: 0 0 6px 6px;
            overflow: hidden;
            box-shadow: 4px 6px 18px rgba(0, 0, 0, 0.2);
            max-width: 1150px;
            margin: 0 auto;
        }

        .sheet {
            display: none;
        }

        .sheet.active {
            display: block;
        }

        /* ── Sheet header ── */
        .sheet-header {
            background: #fff;
            color: #000;
            padding: 18px 28px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 20px;
            flex-wrap: wrap;
            border-bottom: 3px solid #000;
        }

        .worker-name {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 2.6rem;
            letter-spacing: 0.2em;
            color: #000;
        }

        .month-field {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 1rem;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: #000;
            font-weight: 700;
        }

        .month-field input[type="month"] {
            font-family: 'Courier Prime', monospace;
            font-size: 1rem;
            padding: 6px 12px;
            border: 2px solid #000;
            border-radius: 3px;
            background: #fff;
            color: #000;
            cursor: pointer;
            outline: none;
        }

        .month-field input[type="month"]:focus {
            box-shadow: 0 0 0 2px #888;
        }

        /* ── Table ── */
        .table-wrap {
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 1.05rem;
        }

        thead tr th {
            background: #fff;
            color: #000;
            font-family: 'Bebas Neue', sans-serif;
            font-size: 1.05rem;
            letter-spacing: 0.1em;
            padding: 10px 8px;
            text-align: center;
            border-right: 1px solid #999;
            border-top: 1px solid #999;
            border-bottom: 3px solid #000;
            white-space: nowrap;
        }

        thead tr th:first-child {
            width: 56px;
            border-left: none;
        }

        tbody tr {
            border-bottom: 1px solid #bbb;
            transition: background 0.1s;
        }

        tbody tr:nth-child(even) {
            background: #f4f4f4;
        }

        tbody tr:hover {
            background: #e8e8e8;
        }

        tbody tr td {
            padding: 4px 5px;
            border-right: 1px solid #bbb;
            vertical-align: middle;
        }

        .td-date {
            text-align: center;
            font-weight: 700;
            font-size: 1.1rem;
            color: #000;
            width: 56px;
            border-right: 2px solid #000 !important;
            background: #eee;
        }

        tbody tr.weekend {
            opacity: 0.45;
        }

        /* ── Inputs — all black text, bigger numbers ── */
        td input,
        td select {
            font-family: 'Courier Prime', monospace;
            font-size: 1.05rem;
            font-weight: 700;
            width: 100%;
            border: none;
            background: transparent;
            color: #000;
            padding: 5px 4px;
            text-align: center;
            outline: none;
            transition: background 0.12s;
        }

        td input[type="number"] {
            font-size: 1.15rem;
            font-weight: 700;
            color: #000;
        }

        td input[type="text"],
        td input[type="time"] {
            font-size: 1rem;
            font-weight: 400;
            color: #000;
        }

        td input:focus,
        td select:focus {
            background: #f0f0f0;
            border-radius: 2px;
            box-shadow: inset 0 0 0 2px #000;
        }

        td select {
            cursor: pointer;
            appearance: none;
            -webkit-appearance: none;
            font-weight: 700;
            color: #000;
        }

        /* ── Totals row — dark blue + yellow ── */
        .totals-row td {
            background: var(--dark-blue) !important;
            color: var(--yellow) !important;
            font-weight: 700;
            font-size: 1.1rem;
            padding: 8px 5px;
        }

        .totals-row td input {
            color: var(--yellow) !important;
            background: transparent !important;
            font-weight: 700;
            font-size: 1.15rem;
        }

        .totals-row td.td-date {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 0.9rem;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: #a8bcd8 !important;
            background: var(--dark-blue) !important;
        }

        /* ── Footer ── */
        .sheet-footer {
            background: #f2f2f2;
            border-top: 2px solid #000;
            padding: 14px 28px;
            display: flex;
            justify-content: flex-end;
            gap: 12px;
            align-items: center;
            flex-wrap: wrap;
        }

        .btn {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 1.05rem;
            letter-spacing: 0.14em;
            padding: 10px 24px;
            cursor: pointer;
            border-radius: 3px;
            transition: all 0.13s;
            border: 2px solid #000;
        }

        .btn-clear {
            background: #fff;
            color: #000;
        }

        .btn-clear:hover {
            background: #ddd;
        }

        .btn-print {
            background: #fff;
            color: #000;
        }

        .btn-print:hover {
            background: #ddd;
        }

        .btn-submit {
            background: var(--dark-blue);
            color: var(--yellow);
            border-color: var(--dark-blue);
            padding: 10px 32px;
        }

        .btn-submit:hover {
            background: #162a66;
        }

        /* ── Modal ── */
        .modal-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.5);
            z-index: 100;
            align-items: center;
            justify-content: center;
        }

        .modal-overlay.open {
            display: flex;
        }

        .modal {
            background: #fff;
            border: 3px solid var(--dark-blue);
            border-radius: 6px;
            padding: 36px 40px;
            max-width: 420px;
            width: 92%;
            text-align: center;
            box-shadow: 6px 8px 0 var(--dark-blue);
            animation: popIn 0.18s ease;
        }

        @keyframes popIn {
            from {
                transform: scale(0.9);
                opacity: 0;
            }

            to {
                transform: scale(1);
                opacity: 1;
            }
        }

        .modal-check {
            width: 58px;
            height: 58px;
            border: 3px solid var(--dark-blue);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 16px;
            font-size: 1.7rem;
            color: var(--dark-blue);
            background: #eef2ff;
        }

        .modal-title {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 1.7rem;
            letter-spacing: 0.15em;
            margin-bottom: 10px;
            color: var(--dark-blue);
        }

        .modal-body {
            font-size: 0.95rem;
            color: #333;
            line-height: 1.65;
            margin-bottom: 26px;
        }

        .modal-body strong {
            color: var(--dark-blue);
        }

        .btn-modal-close {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 1.05rem;
            letter-spacing: 0.12em;
            padding: 10px 34px;
            border: 2px solid var(--dark-blue);
            background: var(--dark-blue);
            color: var(--yellow);
            cursor: pointer;
            border-radius: 3px;
            transition: background 0.12s;
        }

        .btn-modal-close:hover {
            background: #162a66;
        }

        @media print {
            body {
                background: white;
                padding: 0;
            }

            .tabs,
            .sheet-footer,
            .title-banner,
            .modal-overlay {
                display: none !important;
            }

            .sheet {
                display: block !important;
            }

            .sheet-container {
                border: none;
                box-shadow: none;
            }

            table {
                font-size: 10pt;
            }
        }

        @media (max-width: 600px) {
            .tab-btn {
                padding: 8px 12px;
                font-size: 0.95rem;
            }

            .worker-name {
                font-size: 1.8rem;
            }

            .page-title {
                font-size: 2rem;
            }
        }
    </style>
</head>

<body>

    <div class="title-banner">
        <div class="page-title">Monthly Time Sheet</div>
        <div class="page-subtitle">Production &bull; Sales &bull; Records</div>
    </div>

    <div class="tabs" style="max-width:1150px;margin:0 auto;">
        <button class="tab-btn active" onclick="switchTab(0)">MURUGAN</button>
        <button class="tab-btn" onclick="switchTab(1)">GANAPATHY</button>
        <button class="tab-btn" onclick="switchTab(2)">KANDIPAN</button>
    </div>

    <div class="sheet-container"></div>

    <div class="modal-overlay" id="submitModal">
        <div class="modal">
            <div class="modal-check">✔</div>
            <div class="modal-title">Submitted</div>
            <div class="modal-body" id="modalBody"></div>
            <button class="btn-modal-close" onclick="closeModal()">OK</button>
        </div>
    </div>

    <script>
        const workers = ["MURUGAN", "GANAPATHY", "KANDIPAN"];
        const cols = [
            { key: "shift", label: "SHIFT<br>(A/B/C)", type: "select", opts: ["", "A", "B", "C"] },
            { key: "in", label: "IN", type: "time" },
            { key: "out", label: "OUT", type: "time" },
            { key: "helper", label: "HELPER<br>DUTY", type: "text" },
            { key: "ot", label: "OVER<br>TIME", type: "number" },
            { key: "prod", label: "PROD.", type: "number" },
            { key: "sales", label: "SALES", type: "number" },
            { key: "rej", label: "REJ.", type: "number" },
            { key: "lump", label: "LUMP", type: "number" },
            { key: "others", label: "OTHERS", type: "text" },
        ];

        const now = new Date();
        const defaultMonth = `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, '0')}`;

        function buildSheet(idx) {
            return `
  <div class="sheet${idx === 0 ? ' active' : ''}" id="sheet-${idx}">
    <div class="sheet-header">
      <span class="worker-name">${workers[idx]}</span>
      <div class="month-field">
        <span>Month:</span>
        <input type="month" id="month-${idx}" value="${defaultMonth}" onchange="refreshDays(${idx})" />
      </div>
    </div>
    <div class="table-wrap">
      <table>
        <thead><tr>
          <th>DATE</th>
          ${cols.map(c => `<th>${c.label}</th>`).join('')}
        </tr></thead>
        <tbody id="tbody-${idx}">${buildRows(idx)}</tbody>
      </table>
    </div>
    <div class="sheet-footer">
      <button class="btn btn-clear" onclick="clearSheet(${idx})">Clear</button>
      <button class="btn btn-print" onclick="window.print()">&#9113; Print</button>
      <button class="btn btn-submit" onclick="submitSheet(${idx})">Submit &#10132;</button>
    </div>
  </div>`;
        }

        function buildRows(idx) {
            let html = '';
            for (let d = 1; d <= 31; d++) {
                html += `<tr id="row-${idx}-${d}">
      <td class="td-date">${d}</td>
      ${cols.map(c => `<td>${cellInput(idx, d, c)}</td>`).join('')}
    </tr>`;
            }
            html += `<tr class="totals-row">
    <td class="td-date">TOT.</td>
    ${cols.map(c => ["ot", "prod", "sales", "rej", "lump"].includes(c.key)
                ? `<td><input readonly id="tot-${idx}-${c.key}" value="0"/></td>`
                : `<td></td>`).join('')}
  </tr>`;
            return html;
        }

        function cellInput(idx, day, col) {
            const id = `inp-${idx}-${day}-${col.key}`;
            if (col.type === "select") {
                return `<select id="${id}" oninput="updateTotals(${idx})">
      ${col.opts.map(o => `<option value="${o}">${o}</option>`).join('')}
    </select>`;
            }
            return `<input type="${col.type === 'number' ? 'number' : 'text'}" id="${id}"
    ${col.type === 'number' ? 'min="0" step="1"' : ''}
    oninput="updateTotals(${idx})" />`;
        }

        function updateTotals(idx) {
            ["ot", "prod", "sales", "rej", "lump"].forEach(key => {
                let sum = 0;
                for (let d = 1; d <= 31; d++) {
                    const inp = document.getElementById(`inp-${idx}-${d}-${key}`);
                    if (inp && inp.value) sum += parseFloat(inp.value) || 0;
                }
                const tot = document.getElementById(`tot-${idx}-${key}`);
                if (tot) tot.value = sum % 1 === 0 ? sum : sum.toFixed(2);
            });
        }

        function refreshDays(idx) {
            const month = document.getElementById(`month-${idx}`).value;
            if (!month) return;
            const [y, m] = month.split("-").map(Number);
            const days = new Date(y, m, 0).getDate();
            for (let d = 1; d <= 31; d++) {
                const row = document.getElementById(`row-${idx}-${d}`);
                if (!row) continue;
                if (d > days) { row.style.display = "none"; continue; }
                row.style.display = "";
                const wd = new Date(y, m - 1, d).getDay();
                row.classList.toggle("weekend", wd === 0 || wd === 6);
            }
        }

        function switchTab(idx) {
            document.querySelectorAll('.sheet').forEach((s, i) => s.classList.toggle('active', i === idx));
            document.querySelectorAll('.tab-btn').forEach((b, i) => b.classList.toggle('active', i === idx));
        }

        function clearSheet(idx) {
            if (!confirm(`Clear all data for ${workers[idx]}?`)) return;
            cols.forEach(c => {
                for (let d = 1; d <= 31; d++) {
                    const inp = document.getElementById(`inp-${idx}-${d}-${c.key}`);
                    if (inp) inp.value = "";
                }
            });
            updateTotals(idx);
        }

        function submitSheet(idx) {
            const month = document.getElementById(`month-${idx}`).value;
            const [y, m] = month.split("-").map(Number);
            const monthName = new Date(y, m - 1, 1).toLocaleString('default', { month: 'long', year: 'numeric' });
            const days = new Date(y, m, 0).getDate();
            let filled = 0;
            for (let d = 1; d <= days; d++) {
                const s = document.getElementById(`inp-${idx}-${d}-shift`);
                if (s && s.value) filled++;
            }
            document.getElementById('modalBody').innerHTML =
                `<strong>${workers[idx]}</strong>'s time sheet for <strong>${monthName}</strong> has been submitted successfully.<br><br>` +
                `<span style="color:#666;font-size:0.88rem;">${filled} day${filled !== 1 ? 's' : ''} recorded.</span>`;
            document.getElementById('submitModal').classList.add('open');
        }

        function closeModal() {
            document.getElementById('submitModal').classList.remove('open');
        }

        document.getElementById('submitModal').addEventListener('click', function (e) {
            if (e.target === this) closeModal();
        });

        document.querySelector('.sheet-container').innerHTML = workers.map((_, i) => buildSheet(i)).join('');
        workers.forEach((_, i) => refreshDays(i));
    </script>
</body>

</html>
